digraph UML_Inheritance {

    rankdir=BT;

    graph [
        fontname="Helvetica"
        labelloc="t"
        label="Object-Oriented Inheritance"
    ];

    node [
        shape=record
        style=filled
        fillcolor=gray95
        fontname="Helvetica"
    ];

    edge [
        dir=back
        arrowtail=empty
        arrowsize=1.4
        penwidth=1.5
    ];

    Z [
        label="{Z|+ commonField|+ render()\l+ validate()\l}"
    ];

    X [
        label="{X|+ xField|+ render()\l}"
    ];

    Y [
        label="{Y|+ yField|+ render()\l}"
    ];

    X -> Z;
    Y -> Z;
}
