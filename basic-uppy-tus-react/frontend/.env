# TUS / Uppy upload configuration

# chunk size 
# NOTE: if TUS_CHUNK_SIZE is not set, tus behaves like: send the whole file in one request (effectively no chunking override)
# VITE_TUS_CHUNK_SIZE=5 * 1024 * 1024
VITE_TUS_CHUNK_SIZE=5242880

# retry 
VITE_TUS_RETRY_DELAYS=0,500,1000,3000

# endpoint

VITE_TUS_ENDPOINT=/api/upload

# file restrictions
VITE_MAX_NUMBER_OF_FILES=1

# maximum file size in bytes (default is 2GB)
VITE_MAX_FILE_SIZE_BYTES=2147439648

# show per file speed and ETA alongsize the progressbar
VITE_UPPY_SHOW_PROGRESS_DETAILS=true

# UX behavior
VITE_JOB_REDIRECT_DELAY_MS=500

